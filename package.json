{
  "name": "trimlink",
  "version": "1.0.0",
  "description": "TrimLink URL shortener - Vercel Node API",
  "main": "api/index.js",
  "scripts": {
    "start": "node api/index.js",
    "build:css": "npx @tailwindcss/cli -i ./assets/input.css -o ./assets/style.css --minify",
    "build": "npm run build:css",
    "watch:css": "npx @tailwindcss/cli -i ./assets/input.css -o ./assets/style.css --watch"
  },
  "dependencies": {
    "mysql2": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "tailwindcss": "^4.3.1"
  }
}
